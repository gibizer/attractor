{
    "name": "gravity-space-game",
    "version": "1.0.0",
    "description": "A 2D gravity-based space game using Phaser 4.0 RC",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{json,md}\""
    },
    "devDependencies": {
        "prettier": "^3.8.1",
        "typescript": "^5.6.0",
        "vite": "^5.4.0"
    },
    "dependencies": {
        "phaser": "^4.0.0-rc.6",
        "phaser-box2d": "^1.1.0"
    }
}
